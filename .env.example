# ========== B站账号（必填） ==========
BILIBILI_COOKIE="你的B站Cookie"
BILIBILI_UID="你的B站UID"

# ========== 挂机修炼配置 ==========
# 首选直播间ID；若未开播或未开启弹幕宠物，会自动扫描并切换
HANGUP_ROOM_ID="5456135"

# 历史上确认打出过 +19 的优先房间，逗号分隔，越靠左优先级越高
PET_PRIORITY_ROOMS="1788399444"

# 随机心跳直播间列表（用于B站升级心跳），逗号分隔
RANDOM_ROOMS="732,6,1,76,488,21452505"

# 自动扫描直播间时优先匹配的关键词
PET_ROOM_KEYWORDS="弹幕宠物,修仙,突破,签到,宠物,修炼"

# 每次自动扫描的直播列表页数 / 最多深入检测多少个候选直播间
PET_DISCOVERY_PAGES="2"
PET_DISCOVERY_LIMIT="12"

# 宠物名称
PET_NAME="我的弹幕宠物"

# ========== QQ邮件通知（可选但推荐） ==========
# QQ邮箱地址
QQ_MAIL_USER=""
# QQ邮箱授权码（不是登录密码，在QQ邮箱 → 设置 → 账户 → SMTP服务里生成）
QQ_MAIL_PASS=""

# ========== 边界AI签到（可选） ==========
# 从 yyai8.com F12 → Network → 点击「立即签到」→ Request Headers 里复制
YYAI_TOKEN=""
YYAI_ACCESS_TOKEN=""
YYAI_UID=""

# ========== 任务控制 ==========
# all | signin | hangup | pet
TASK="all"
